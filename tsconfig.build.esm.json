    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist/esm",
    "rootDir": "./"
  },
  "include": ["index.ts"],
  "exclude": ["node_modules", "dist", "index.test.ts"]
}
