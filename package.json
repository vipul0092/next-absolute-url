{
  "name": "@vipul0092/next-absolute-url",
  "version": "1.0.0",
  "description": "Get the absolute URL of a Next.js request. Works with both Pages Router and App Router.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc -p tsconfig.build.json && tsc -p tsconfig.build.esm.json",
    "test": "jest",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build",
    "verify": "pnpm test && pnpm lint",
    "changeset": "changeset",
    "bump": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:dry": "pnpm build && pnpm pack --dry-run"
  },
  "keywords": [
    "nextjs",
    "next",
    "absolute-url",
    "url",
    "app-router",
    "pages-router"
  ],
  "author": "Vipul Gaur <sunny3091@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@swc/core": "^1.15.32",
    "@swc/jest": "^0.2.39",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.0.0",
    "jest": "^30.0.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
